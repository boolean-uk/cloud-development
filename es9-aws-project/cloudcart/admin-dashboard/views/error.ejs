<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; height: 100vh; }
    .error { background: white; border-radius: 8px; padding: 3rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); text-align: center; max-width: 500px; }
    .error h1 { color: #d32f2f; margin-bottom: 1rem; }
    .error p { color: #5f6368; margin-bottom: 2rem; }
    .error a { display: inline-block; background: #1a73e8; color: white; padding: 0.8rem 1.5rem; border-radius: 4px; text-decoration: none; }
    .error a:hover { background: #1557b0; }
  </style>
</head>
<body>
  <div class="error">
    <h1>Error</h1>
    <p><%= error %></p>
    <a href="/">Go to Dashboard</a>
  </div>
</body>
</html>
